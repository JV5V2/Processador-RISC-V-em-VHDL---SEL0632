library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;
use work.riscv_pkg.all; -- (Item i)

entity dmem is
    -- (Item ii: ParametrizaþÒo)
    generic(RISCV_Data_Width : integer := 32);
    port(
        clk, we: in STD_LOGIC;
        a, wd: in STD_LOGIC_VECTOR(RISCV_Data_Width-1 downto 0);
        rd: out STD_LOGIC_VECTOR(RISCV_Data_Width-1 downto 0)
    );
end;

architecture behave of dmem is
    type ramtype is array (63 downto 0) of STD_LOGIC_VECTOR(RISCV_Data_Width-1 downto 0);
    signal mem: ramtype;
begin
    process(clk, a) begin
        if rising_edge(clk) then
            if (we = '1') then 
                mem(to_integer(unsigned(a(7 downto 2)))) <= wd;
            end if;
        end if;
        rd <= mem(to_integer(unsigned(a(7 downto 2))));
    end process;
end;
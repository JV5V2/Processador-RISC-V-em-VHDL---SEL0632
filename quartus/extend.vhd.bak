library ieee;
use ieee.std_logic_1164.all;

entity extend is
    port (
        imm_src : in  std_logic_vector(1 downto 0);
        instr   : in  std_logic_vector(31 downto 7);
        imm_ext : out std_logic_vector(31 downto 0)
    );
end entity extend;

architecture behavioral of extend is
begin

    process(imm_src, instr)
    begin
        case imm_src is
            when "00" =>
                imm_ext <= (19 downto 0 => instr(31)) & instr(31 downto 20);

            when "01" =>
                imm_ext <= (19 downto 0 => instr(31)) & instr(31 downto 25) & instr(11 downto 7);

            when "10" =>
                imm_ext <= (19 downto 0 => instr(31)) & instr(7) & instr(30 downto 25) & instr(11 downto 8) & '0';

            when "11" =>
                imm_ext <= (11 downto 0 => instr(31)) & instr(19 downto 12) & instr(20) & instr(30 downto 21) & '0';

            when others =>
                imm_ext <= (others => 'X');
        end case;
    end process;

end architecture behavioral;
library IEEE;
use IEEE.STD_LOGIC_1164.ALL;

ENTITY mux3 IS
PORT (

	entrada_A : in  std_logic_vector(31 downto 0);
   entrada_B : in  std_logic_vector(31 downto 0);
   entrada_C : in  std_logic_vector(31 downto 0);
	S         : in std_logic_vector(1 downto 0);
	y     : out std_logic_vector(31 downto 0)
);
		 
END mux3;

ARCHITECTURE funcionamento OF mux3 IS
  
  BEGIN
  WITH s SELECT 
	y <=	entrada_A when "00",
            entrada_B when "01",
            entrada_C when "10",
				(others => '0') when others;
  
END funcionamento;
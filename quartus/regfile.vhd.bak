LIBRARY ieee;
USE ieee.std_logic_1164.ALL;
USE ieee.numeric_std.ALL;

ENTITY regfile IS
    PORT (
        CLK : IN  STD_LOGIC;
        WE3 : IN  STD_LOGIC;
        A1  : IN  STD_LOGIC_VECTOR(4 DOWNTO 0);
        A2  : IN  STD_LOGIC_VECTOR(4 DOWNTO 0);
        A3  : IN  STD_LOGIC_VECTOR(4 DOWNTO 0);
        WD3 : IN  STD_LOGIC_VECTOR(31 DOWNTO 0);
        RD1 : OUT STD_LOGIC_VECTOR(31 DOWNTO 0);
        RD2 : OUT STD_LOGIC_VECTOR(31 DOWNTO 0)
    );
END ENTITY regfile;

ARCHITECTURE behavioral OF regfile IS

    TYPE reg_array_type IS ARRAY (0 TO 31) OF STD_LOGIC_VECTOR(31 DOWNTO 0);
    SIGNAL register_bank : reg_array_type := (OTHERS => (OTHERS => '0'));

BEGIN

    write_process: PROCESS (CLK)
    BEGIN
        IF rising_edge(CLK) THEN
            IF WE3 = '1' THEN
                register_bank(to_integer(unsigned(A3))) <= WD3;
            END IF;
        END IF;
    END PROCESS write_process;

    RD1 <= register_bank(to_integer(unsigned(A1)));
    RD2 <= register_bank(to_integer(unsigned(A2)));

END ARCHITECTURE behavioral;
entity SLT is
GENERIC(N: INTEGER:=32);
    PORT (
        A, B : in  bit_vector(N-1 downto 0);
        r    : out bit_vector(N-1 downto 0)
    );
END SLT;

ARCHITECTURE of SLT is
begin

    --  A  B
    r(0) <= '1' when (A(2) = B(2) and A(1) = B(1) and A(0) = B(0)) else '0'; -- A >= B
				'0' when -- A < B
end a;